<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style.css">
    <title>Register - GX Bet</title>
</head>
<body style="background: white;">
    <div style="padding: 40px 20px;">
        <h2 style="color: var(--primary-red);">Create Account</h2>
        <p style="color: #666; font-size: 14px;">Enter your mobile number to get started.</p>
        
        <div style="margin-top: 30px;">
            <label style="font-size: 12px; font-weight: bold;">Mobile Number</label>
            <div style="display: flex; border-bottom: 2px solid #ddd; margin-bottom: 20px;">
                <span style="padding: 10px 5px; font-weight: bold;">+256</span>
                <input type="tel" placeholder="700 000 000" style="border:none; outline:none; padding:10px; flex:1;">
            </div>

            <label style="font-size: 12px; font-weight: bold;">Set Password</label>
            <input type="password" placeholder="Minimum 6 characters" style="width:100%; border:none; border-bottom: 2px solid #ddd; padding:10px 0; margin-bottom: 30px; outline:none;">

            <button onclick="location.href='index.html'" style="width:100%; background:var(--primary-red); color:white; border:none; padding:15px; border-radius:4px; font-weight:bold; font-size:16px;">Next</button>
        </div>
    </div>
</body>
</html>
